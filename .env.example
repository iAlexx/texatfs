# Copy to .env.local - never commit real secrets

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram Mini App
TELEGRAM_BOT_TOKEN=

# Local dev: seed user telegram_id (e.g. 1000000002 = Master in seed.sql)
NEXT_PUBLIC_DEV_TELEGRAM_ID=

# Fallback poll when Realtime auth is not yet wired (ms)
NEXT_PUBLIC_LEDGER_POLL_MS=15000

# Texas agent dashboard API (must include /global/api on agents host)
TEXAS_API_BASE_URL=https://agents.texas4win.com/global/api

# Residential proxy for Texas API (bypass Cloudflare 403 on Vercel)
# Format: http://username:password@host:port
TEXAS_HTTP_PROXY=
TEXAS_DEFAULT_CURRENCY=NSP
TEXAS_SYNC_USERNAME=
TEXAS_SYNC_PASSWORD=

# Optional smoke-test mapping context
TEXAS_SYNC_USER_ID=live-smoke-test
TEXAS_SYNC_ROLE=master
TEXAS_SYNC_AFFILIATE_ID=
TEXAS_SYNC_PAGE_SIZE=1000

# Business timezone for ledger_date and daily close cron
LEDGER_TIMEZONE=Asia/Damascus

# Phase 5 — SaaS licensing (32+ byte secret for AES-256-GCM)
CREDENTIALS_ENCRYPTION_KEY=

# Comma-separated Telegram user IDs allowed to run /genkey
TELEGRAM_ADMIN_IDS=

# Mini App URL shown after registration (e.g. https://your-app.vercel.app/ledger)
TELEGRAM_MINI_APP_URL=
NEXT_PUBLIC_APP_URL=

# Optional webhook verification header
TELEGRAM_WEBHOOK_SECRET=
