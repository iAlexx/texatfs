# Copy to .env.local - never commit real secrets

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram Mini App
TELEGRAM_BOT_TOKEN=

# Local dev: poll getUpdates → localhost (npm run telegram:poll). Do not use with production webhook.
# TELEGRAM_DEV_WEBHOOK_URL=http://127.0.0.1:3000/api/telegram/webhook
# TELEGRAM_DEV_LOG=true

# Production webhook URL for npm run telegram:check comparison
# TELEGRAM_PRODUCTION_WEBHOOK_URL=https://your-app.up.railway.app/api/telegram/webhook

# Local dev: seed user telegram_id (e.g. 1000000002 = Master in seed.sql)
NEXT_PUBLIC_DEV_TELEGRAM_ID=

# Fallback poll when Realtime auth is not yet wired (ms)
NEXT_PUBLIC_LEDGER_POLL_MS=15000

# Texas agent dashboard API (must include /global/api on agents host)
TEXAS_API_BASE_URL=https://agents.texas4win.com/global/api

# Residential proxy for Texas API (required for Cloudflare bypass)
# Example: http://username:password@host:port (Verizon 5G residential recommended)
TEXAS_HTTP_PROXY=

# Local laptop debug: headed Chrome, no proxy, screenshots in .texas-debug/
# LOCAL_DEBUG=true

# Puppeteer UI sign-in (puppeteer-extra + stealth). Set false to use HTTP warm-up only.
TEXAS_BROWSER_LOGIN=true
# Retry with undici fetch only when true (not recommended on Railway).
TEXAS_BROWSER_LOGIN_FALLBACK=false

# Railway Docker sets this automatically; override for local Linux if needed
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# TEXAS_BROWSER_HEADED=true
# BROWSERLESS_WS_ENDPOINT=wss://chrome.browserless.io?token=YOUR_TOKEN
TEXAS_DEFAULT_CURRENCY=NSP
TEXAS_SYNC_USERNAME=
TEXAS_SYNC_PASSWORD=

# Optional smoke-test mapping context
TEXAS_SYNC_USER_ID=live-smoke-test
TEXAS_SYNC_ROLE=master
TEXAS_SYNC_AFFILIATE_ID=
TEXAS_SYNC_PAGE_SIZE=1000

# Business timezone for ledger_date and daily close cron
LEDGER_TIMEZONE=Asia/Damascus

# Per-user ledger sync freshness (minutes) — used for deep-dive & agents tab
LEDGER_STALE_MINUTES=15
# Max subtree members to auto-sync per request (agents tab / network)
LEDGER_NETWORK_SYNC_MAX=8

# Phase 2C — automated daily sync + report images (23:50 cron via Railway/external scheduler)
CRON_SECRET=
# Optional: separate token for /api/render/report/[id] (defaults to CRON_SECRET)
# REPORT_RENDER_SECRET=
# Base URL Puppeteer uses to load report HTML (production app URL)
REPORT_RENDER_BASE_URL=https://your-app.up.railway.app
# Delay between each user's Texas sync (ms) — default 60000 (60s)
CRON_USER_DELAY_MS=60000
# Return 202 immediately and run sync in background (default true)
# CRON_DAILY_SYNC_ASYNC=true

# Phase 5 — SaaS licensing (32+ byte secret for AES-256-GCM)
CREDENTIALS_ENCRYPTION_KEY=

# Comma-separated Telegram user IDs allowed to run /genkey
TELEGRAM_ADMIN_IDS=

# Mini App URL shown after registration (e.g. https://your-app.vercel.app/ledger)
TELEGRAM_MINI_APP_URL=
NEXT_PUBLIC_APP_URL=

# Optional webhook verification header (polling dev script forwards this header)
TELEGRAM_WEBHOOK_SECRET=

# Return 200 immediately; run onboarding/Puppeteer in background (default true)
# TELEGRAM_WEBHOOK_ASYNC=true
