# Railway production variables — paste into Railway → Service → Variables
# Do NOT set LOCAL_DEBUG on Railway.

# --- Required ---
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CREDENTIALS_ENCRYPTION_KEY=

TEXAS_API_BASE_URL=https://agents.texas4win.com/global/api
TEXAS_BROWSER_LOGIN=true
TEXAS_BROWSER_LOGIN_FALLBACK=false

# Residential proxy (strongly recommended on Railway/datacenter IPs)
TEXAS_HTTP_PROXY=http://username:password@host:port

# Set after first deploy (public HTTPS URL)
NEXT_PUBLIC_APP_URL=https://your-service.up.railway.app
TELEGRAM_MINI_APP_URL=https://your-service.up.railway.app/ledger
TELEGRAM_PRODUCTION_WEBHOOK_URL=https://your-service.up.railway.app/api/telegram/webhook

TELEGRAM_ADMIN_IDS=
LEDGER_TIMEZONE=Asia/Damascus
TEXAS_DEFAULT_CURRENCY=NSP

# --- Set by Dockerfile (do not override unless debugging) ---
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# HOSTNAME=0.0.0.0

# --- Recommended production ---
TELEGRAM_WEBHOOK_ASYNC=true
NODE_OPTIONS=--max-old-space-size=2048

# --- Do NOT set on Railway ---
# LOCAL_DEBUG=
# TELEGRAM_DEV_WEBHOOK_URL=
# TEXAS_BROWSER_HEADED=true
